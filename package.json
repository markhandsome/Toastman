{
  "name": "api-client",
  "version": "1.0.0",
  "description": "Postman-style API testing tool with team sync",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "proxy": "node proxy.js"
  },
  "build": {
    "appId": "com.apiclient.app",
    "productName": "API Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "js/**/*",
      "css/**/*",
      "icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "API Client"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
